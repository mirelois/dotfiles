/* Message Dialog */

@import "black_powermenu.rasi"

* {
    background-color:       @background;
    text-color:             @selected;
    font:"Monocraft 11";
}

window {
    width:      435px;
    padding:    25px;
    border:1px;
    border-radius:          12px;
    border-color:           @border;
    location:               center;
    y-offset:               -2em;
}

entry {
    expand: true;
    text-color:@border;
}
